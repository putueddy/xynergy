  "query": "SELECT id, start_date, end_date, allocation_percentage, include_weekend\n             FROM allocations \n             WHERE resource_id = $1 \n             AND (\n                 (start_date <= $2 AND end_date >= $2) OR\n                 (start_date <= $3 AND end_date >= $3) OR\n                 (start_date >= $2 AND end_date <= $3)\n             )",
