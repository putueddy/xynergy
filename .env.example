# Environment Variables

# Database
DATABASE_URL=postgres://xynergy_user:your_password@localhost:5432/xynergy

# Application
APP_ENV=development
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=3600

# CTC Field Encryption (AES-256-GCM)
CTC_ACTIVE_KEY_VERSION=v1
CTC_ENCRYPTION_KEY_V1=replace-with-base64-32-byte-key

# Logging
RUST_LOG=info
